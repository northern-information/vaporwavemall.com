{
  "type": "module",
  "scripts": {
    "dev": "npx @11ty/eleventy --serve",
    "dev:css": "npx @tailwindcss/cli -i ./src/assets/stylesheets/style.css -o ./src/assets/stylesheets/style.built.css --watch",
    "dev:ts": "npx tsc --watch",
    "build:ts": "npx tsc",
    "build:css": "npx @tailwindcss/cli -i ./src/assets/stylesheets/style.css -o ./src/assets/stylesheets/style.built.css --minify",
    "build": "npm run build:ts && npm run build:css && npx @11ty/eleventy",
    "pretty": "prettier --write .",
    "discography": "npm install @tyleretters/discography@latest && cp ./node_modules/@tyleretters/discography/dist/discography.yml src/data/discography.yml"
  },
  "dependencies": {
    "@tyleretters/discography": "^1.0.3"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@shopify/prettier-plugin-liquid": "^1.9.3",
    "@tailwindcss/cli": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.7.0"
  }
}
